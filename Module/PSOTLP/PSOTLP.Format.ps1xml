<?xml version="1.0" encoding="utf-8"?>
<Configuration>
  <ViewDefinitions>

    <View>
      <Name>PSOTLP.Connections.OTLPConnection</Name>
      <ViewSelectedBy>
        <TypeName>PSOTLP.Connections.OTLPConnection</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>ServiceName</Label></TableColumnHeader>
          <TableColumnHeader><Label>EndpointUri</Label></TableColumnHeader>
          <TableColumnHeader><Label>LogsEndpointUri</Label></TableColumnHeader>
          <TableColumnHeader><Label>Transport</Label></TableColumnHeader>
          <TableColumnHeader><Label>Encoding</Label></TableColumnHeader>
          <TableColumnHeader><Label>Compression</Label></TableColumnHeader>
          <TableColumnHeader><Label>IsConnected</Label></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>ServiceName</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>EndpointUri</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>LogsEndpointUri</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Transport</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Encoding</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Compression</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>IsConnected</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>PSOTLP.Exporters.OTLPExportResult</Name>
      <ViewSelectedBy>
        <TypeName>PSOTLP.Exporters.OTLPExportResult</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>SignalType</Label></TableColumnHeader>
          <TableColumnHeader><Label>EndpointUri</Label></TableColumnHeader>
          <TableColumnHeader><Label>StatusCode</Label></TableColumnHeader>
          <TableColumnHeader><Label>RecordCount</Label></TableColumnHeader>
          <TableColumnHeader><Label>AttemptCount</Label></TableColumnHeader>
          <TableColumnHeader><Label>Success</Label></TableColumnHeader>
          <TableColumnHeader><Label>ExportedAtUtc</Label></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>SignalType</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>EndpointUri</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>StatusCode</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>RecordCount</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>AttemptCount</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Success</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>ExportedAtUtc</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

  </ViewDefinitions>
</Configuration>
